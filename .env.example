# ===========================================
# SysPrompt Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# -------------------------------------------
# OpenRouter API (Required)
# -------------------------------------------
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXX

# -------------------------------------------
# WorkOS Authentication
# -------------------------------------------
# Get from: https://dashboard.workos.com → API Keys

# Client ID (public, used in frontend)
VITE_WORKOS_CLIENT_ID=client_01XXXXXXXXXXXXXXXXXXXXXX

# NOTE: WORKOS_CLIENT_ID must also be set in Convex Dashboard!
# Go to: https://dashboard.convex.dev → Your Project → Settings → Environment Variables
# Add: WORKOS_CLIENT_ID = client_01XXXXXXXXXXXXXXXXXXXXXX (same value as above)

# -------------------------------------------
# Convex Database
# -------------------------------------------
# These are auto-generated by `bunx convex dev`

# Deployment identifier (format: dev:project-name-123)
CONVEX_DEPLOYMENT=dev:your-project-name

# Public Convex URL (used in frontend)
VITE_CONVEX_URL=https://your-project-name.convex.cloud
